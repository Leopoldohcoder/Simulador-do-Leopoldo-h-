rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }
    function ehAdmin() {
      return estaAutenticado() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{uid} {
      allow read: if estaAutenticado() && (request.auth.uid == uid || ehAdmin());
      allow create: if estaAutenticado() && request.auth.uid == uid;
      allow update: if estaAutenticado() && (request.auth.uid == uid || ehAdmin());
    }

    match /questions/{id} {
      allow read: if estaAutenticado();
      allow write: if ehAdmin();
    }

    match /results/{id} {
      allow read: if estaAutenticado() && (resource.data.uid == request.auth.uid || ehAdmin());
      allow create: if estaAutenticado() && request.resource.data.uid == request.auth.uid;
    }

    match /ranking/{uid} {
      allow read: if estaAutenticado();
      allow write: if estaAutenticado() && request.auth.uid == uid;
    }

    match /materials/{id} {
      allow read: if estaAutenticado();
      allow write: if ehAdmin();
    }
    match /notifications/{id} {
      allow read: if estaAutenticado();
      allow write: if ehAdmin();
    }
  }
}
